# How this deployment authenticates: "oidc" (an external IdP owns identity) or
# "local" (the server manages username/password accounts itself).
AUTH_MODE=oidc

# --- AUTH_MODE=oidc ---
# The API verifies IdP-issued tokens against the issuer's JWKS; it never mints
# tokens of its own. Users are provisioned on their first authenticated
# request; manage accounts and groups in the IdP (e.g. Authentik).
OIDC_ISSUER=https://authentik.example.com/application/o/halo/
OIDC_CLIENT_ID=change-me
# Members of this IdP group (by UUID — survives renames) are admins.
OIDC_ADMIN_GROUP=change-me

# --- AUTH_MODE=local ---
# The API mints its own session tokens (HS256) and stores scrypt password
# hashes. On first boot an "admin" user is created from ADMIN_PASSWORD; after
# that, manage users via the admin API and change passwords in-app.
# JWT_SECRET must be at least 32 chars, e.g. `openssl rand -base64 48`.
# ADMIN_PASSWORD=change-me
# JWT_SECRET=change-me-too

# Where halo.sqlite lives. Created if missing.
DATA_DIR=./data

PORT=8787

# Extra CORS origins (comma-separated) besides localhost dev + halo.ditto.moe.
# CORS_ORIGINS=
