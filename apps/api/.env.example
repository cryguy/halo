# Seeds the initial admin user (username: admin) on first boot when the users
# table is empty. Consulted only then — afterwards admin is a normal user row and
# this value is never used for login again. Manage users via the /users API.
ADMIN_PASSWORD=change-me

# Secret for signing session JWTs. Generate: openssl rand -hex 32
JWT_SECRET=change-me-too

# Where halo.sqlite lives. Created if missing.
DATA_DIR=./data

PORT=8787

# Extra CORS origins (comma-separated) besides localhost dev + halo.ditto.moe.
# CORS_ORIGINS=
