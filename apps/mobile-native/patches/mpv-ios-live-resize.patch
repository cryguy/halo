++    int w = (int)s.width;
++    int h = (int)s.height;
++
++    if (w > 0 && h > 0 && (w != p->last_width || h != p->last_height)) {
++        if (!resize(ctx))
++            return VO_ERROR;
++        *events |= VO_EVENT_RESIZE;
++    }
++
++    return VO_TRUE;
 +}
