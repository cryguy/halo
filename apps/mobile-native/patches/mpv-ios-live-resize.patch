++    // drawable size must not fail the whole video chain. The control path
++    // re-syncs the swapchain on the next VOCTRL_CHECK_EVENTS poll.
++    bool ok = resize(ctx);
++    MP_VERBOSE(ctx, "moltenvk reconfig (best-effort) -> %d\n", ok);
 +    return true;
 +}
 +
 +static int moltenvk_control(struct ra_ctx *ctx, int *events, int request, void *arg)
 +{
-+    return VO_NOTIMPL;
++    if (request != VOCTRL_CHECK_EVENTS)
