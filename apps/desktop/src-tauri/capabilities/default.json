{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-fullscreen",
    "core:window:allow-is-fullscreen",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://**" },
        { "url": "https://**:*" },
        { "url": "http://**" },
        { "url": "http://**:*" }
      ]
    }
  ]
}
